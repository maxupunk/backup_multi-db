# Timezone e configurações gerais
# PORT = porta interna da aplicação
# DOCKER_EXTERNAL_PORT = porta publicada no host; deixe vazio para automática
TZ=America/Sao_Paulo
PORT=3333
DOCKER_EXTERNAL_PORT=
HOST=localhost
LOG_LEVEL=info
NODE_ENV=development

# Chave de criptografia da aplicação (obrigatória)
# Gere com: node ace generate:key
APP_KEY=

# Chave para criptografia das senhas dos bancos de dados
# IMPORTANTE: Use uma chave forte de 32 caracteres para AES-256
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=

# Diretório onde os backups serão armazenados
BACKUP_STORAGE_PATH=./storage/backups

# Configurações de retenção (em dias)
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=12
RETENTION_YEARLY=5
