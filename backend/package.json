{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "docker:dev": "docker compose --env-file ../.env -f ../docker-compose.dev.yml up --build"
  },
  "imports": {
    "#generated/*": "./.adonisjs/server/*.js",
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.1.0",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^4.2.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/archiver": "^7.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.18",
    "@types/pg": "^8.16.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "eslint": "^9.26.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.3.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/transmit": "^3.0.1",
    "@aws-sdk/client-s3": "^3.956.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@azure/storage-blob": "^12.29.1",
    "@google-cloud/storage": "^7.18.0",
    "@types/node-cron": "^3.0.11",
    "@vinejs/vine": "^4.3.1",
    "adonis-autoswagger": "^3.73.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.5.0",
    "luxon": "^3.7.2",
    "mysql2": "^3.16.0",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "ssh2-sftp-client": "^12.0.1"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "@swc/core"],
    "overrides": {
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "brace-expansion@^1": "1.1.13",
      "brace-expansion@^2": "2.0.3"
    }
  }
}
