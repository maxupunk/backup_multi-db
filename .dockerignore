# =============================================================================
# .dockerignore - DB Backup Manager
# Build context: project root (..)
# =============================================================================

# --- Dependências (platform-native, devem ser compiladas dentro do container)
node_modules/
backend/node_modules/
frontend/node_modules/

# --- Builds locais
backend/build/
frontend/dist/
frontend/dev-dist/

# --- Git
.git/
.gitignore

# --- Logs
*.log
backend/tmp/

# --- Arquivos de ambiente (nunca enviar ao container)
.env
.env.*
!.env.example

# --- Dados locais (montados via volume)
backend/storage/backups/
backend/storage/database/

# --- Editores / IDEs
.vscode/
.idea/
*.swp
*.swo

# --- OS
.DS_Store
Thumbs.db
